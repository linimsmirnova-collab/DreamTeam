POST {{baseUrl}}/api/room/join
Content-Type: {{contentType}}

{
  "roomCode": "{{testRoomCode}}",
  "nickname": "Player4"
}

###

# 🔹 5. ПРОВЕРИТЬ CAN-START (от создателя)
# Запустите этот запрос в ТОЙ ЖЕ сессии, где создавали комнату!
# @name checkCanStart
POST {{baseUrl}}/api/room/can-start
Content-Type: {{contentType}}

> {%
    const d = response.body;
    const status = d.canStart ? "🎉 МОЖНО НАЧАТЬ" : "❌ ЗАБЛОКИРОВАНО";
    client.log(status);
    client.log("Причина: " + (d.reason || "—"));
    if (d.canStart) {
        client.log("✅ Кнопку можно активировать!");
    }
%}

###

# 🔹 6. ПОЛУЧИТЬ СПИСОК ИГРОКОВ
# @name getPlayers
GET {{baseUrl}}/api/room/players
Content-Type: {{contentType}}

###

# 🔹 7. ТЕСТ: Присоединиться с уже занятым ником
# @name joinDuplicate
POST {{baseUrl}}/api/room/join
Content-Type: {{contentType}}

{
  "roomCode": "{{testRoomCode}}",
  "nickname": "Player2"
}

###

# 🔹 8. ТЕСТ: Присоединиться к несуществующей комнате
# @name joinNotFound
POST {{baseUrl}}/api/room/join
Content-Type: {{contentType}}

{
  "roomCode": "XXXXXX",
  "nickname": "Ghost"
}

###

# 🔹 9. ТЕСТ: Создать комнату с недопустимым количеством игроков
# @name createInvalid
POST {{baseUrl}}/api/room/create
Content-Type: {{contentType}}

{
  "nickname": "Test",
  "playersCount": 2,
  "randomEvents": false
}

###