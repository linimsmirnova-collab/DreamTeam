# ===== ТЕСТ СЕРВЕРА ПО КОДУ КОМНАТЫ =====
# Используйте с расширением "REST Client" для VS Code
# Запускайте запросы через "Send Request" (Ctrl+Alt+R)

@baseUrl = http://localhost:3000
@contentType = application/json

###

# 🔹 1. СОЗДАТЬ КОМНАТУ
# @name createRoom
POST {{baseUrl}}/api/room/create
Content-Type: {{contentType}}

{
  "nickname": "Creator",
  "playersCount": 4,
  "randomEvents": false
}

> {%
    // Сохраняем roomId для следующих запросов
    client.global.set("testRoomCode", response.body.roomId);
    client.log("🏠 Комната создана: " + response.body.roomId);
%}

###

# 🔹 2. ПРИСОЕДИНИТЬСЯ КАК ИГРОК 2
# @name joinPlayer2
POST {{baseUrl}}/api/room/join
Content-Type: {{contentType}}

{
  "roomCode": "{{testRoomCode}}",
  "nickname": "Player2"
}

> {%
    client.log("✅ Player2 присоединился");
%}

###

# 🔹 3. ПРИСОЕДИНИТЬСЯ КАК ИГРОК 3
# @name joinPlayer3
POST {{baseUrl}}/api/room/join
Content-Type: {{contentType}}

{
  "roomCode": "{{testRoomCode}}",
  "nickname": "Player3"
}

###

# 🔹 4. ПРИСОЕДИНИТЬСЯ КАК ИГРОК 4
