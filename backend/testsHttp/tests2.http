# ===== НАСТРОЙКИ =====
@baseUrl = http://localhost:3000
@contentType = application/json

# -------------------------------------------
# 🔹 ШАГ 1: Создаём комнату + ОТЛАДКА
# -------------------------------------------
# @name step1_create
POST {{baseUrl}}/api/room/create
Content-Type: {{contentType}}

{
  "nickname": "Creator",
  "playersCount": 4,
  "randomEvents": false
}

> {%
    // Сохраняем roomId
    const roomId = response.body.roomId;
    client.global.set("testRoomId", roomId);
    
    // Логи для отладки
    client.log("🏠 Комната создана: " + roomId);
    client.log("🔍 testRoomId сохранён: " + client.global.get("testRoomId"));
%}

###

# 🔹 ШАГ 2: Присоединение Игрока 2 + ОТЛАДКА
# @name step3_join_player2
POST {{baseUrl}}/api/room/join
Content-Type: {{contentType}}

{
  "roomCode": "{{testRoomId}}",
  "nickname": "Player2"
}

> {%
    // Показываем, что реально отправляется
    const body = JSON.parse(request.body);
    client.log("🔍 Отправляю roomCode: '" + body.roomCode + "'");
    
    if (!body.roomCode || body.roomCode.includes('{{')) {
        client.log("❌ ОШИБКА: переменная не подставилась!");
    } else {
        client.log("✅ Переменная подставлена верно");
    }
%}

###

# 🔹 ШАГ 3: Проверка can-start
# @name step_check
POST {{baseUrl}}/api/room/can-start
Content-Type: {{contentType}}

###